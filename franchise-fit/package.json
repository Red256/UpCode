{
  "name": "franchise-fit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js",
    "build": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "stats:national": "node scripts/computeNationalTractZStats.mjs",
    "precompute:tracts": "node scripts/precomputeAllTractScores.mjs",
    "download:boundaries": "node scripts/downloadTractBoundaries.mjs",
    "build:state-bbox": "node scripts/computeStateTractLayerBbox.mjs",
    "build:tract-areas": "node scripts/buildTractGeoidAreaSqMi.mjs",
    "stats:student-density": "node scripts/mergeStudentPerSqMiNational.mjs",
    "download:places": "node scripts/downloadUsPlaces.mjs",
    "download:tract-history": "node scripts/downloadTractAcsHistory.mjs",
    "download:all": "npm run download:places && npm run download:boundaries && npm run download:tract-history",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@turf/area": "^7.3.5",
    "@turf/bbox": "^7.3.4",
    "@turf/boolean-intersects": "^7.3.4",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/centroid": "^7.3.4",
    "@turf/circle": "^7.3.4",
    "@turf/distance": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "chart.js": "^4.5.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
