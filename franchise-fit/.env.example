# Supabase Configuration (Required for production)
# Get these from: Supabase Dashboard → Settings → API

# IMPORTANT: Use the LEGACY anon key (starts with eyJ...), NOT the new publishable key!
# The new publishable keys (sb_publishable_...) do NOT work with RPC functions
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-legacy-anon-key-here

# Optional: If not set, app uses local CSV files as fallback
